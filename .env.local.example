# Copie este arquivo para .env.local e preencha com seus valores reais.
# Nunca faça commit do .env.local.

# Supabase (pegue em https://app.supabase.com > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ey...

# Service role (use APENAS em rotas server-side, nunca exponha)
SUPABASE_SERVICE_ROLE_KEY=ey...

# URL pública do site (usada em metadata e sitemap)
NEXT_PUBLIC_SITE_URL=https://arquitetamariana.com.br

# Email do admin (Mariana). Usado para checagem extra em middleware.
ADMIN_EMAIL=mariana@arquitetamariana.com.br
